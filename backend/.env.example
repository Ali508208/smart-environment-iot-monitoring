# ─── Server ────────────────────────────────────────────────
PORT=5000

# ─── MongoDB ───────────────────────────────────────────────
# Local:   mongodb://localhost:27017/iot-monitoring
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/iot-monitoring
MONGODB_URI=mongodb://localhost:27017/iot-monitoring

# ─── MQTT Broker ───────────────────────────────────────────
# Local Mosquitto: mqtt://localhost:1883
# Cloud HiveMQ:    mqtt://broker.hivemq.com:1883
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ─── Frontend Origin (CORS) ─────────────────────────────────
CORS_ORIGIN=http://localhost:5173
